# ── Local Development Mode ──────────────────────────────────────────────
# Set USE_SQLITE=true untuk local dev (tidak perlu MySQL).
# Hapus atau set false jika deploy ke VPS dengan MySQL.
USE_SQLITE=false

# Database (dipakai jika USE_SQLITE=false)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pddikti_explorer

# JWT Secret
JWT_SECRET=pddikti-super-secret-key-2026-jangan-diubah-sembarangan
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Auto-logout inactivity (seconds) - 30 minutes
INACTIVITY_TIMEOUT=1800

# Admin default credentials (only used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS - izinkan semua origin (untuk development)
CORS_ORIGINS=*
